# 複製這個檔案成 .env 並填入你的金鑰

# === bot.py（主要儲存到 Notion 的 bot）===
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
NOTION_TOKEN=
NOTION_DATABASE_ID=

# === xiaofa_bot.py（小發 Threads 自動發文 bot）===
XIAOFA_BOT_TOKEN=
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# === get_token.py（換 Threads 長效 Token 用）===
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=https://localhost
