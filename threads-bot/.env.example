# 複製這個檔案成 .env 並填入你的金鑰
# 注意：實際部署建議用 Infisical / 1Password / Doppler 等 secret manager 取代 .env

# === 必填 ===

# Telegram Bot Token：跟 @BotFather 申請
TELEGRAM_TOKEN=

# Notion Internal Integration Token（ntn_ 或 secret_ 開頭）
# 取得方式：notion.so/profile/integrations → 建立新的 internal integration
NOTION_TOKEN=

# Notion Database ID
# 從 database URL 抓：notion.so/xxxxxxxxxxxx?v=... 中間那串 32 位字
NOTION_DATABASE_ID=

# Anthropic API Key (sk-ant-xxx)
# 取得方式：console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# 你的 Telegram User ID（避免被別人亂用，設 0 = 不限制）
# 取得方式：在 Telegram 找 @userinfobot 對話一下就會給你
ALLOWED_USER_ID=

# === 選填：登入 cookie（爬未公開 / 改版後的 Threads 貼文） ===
# 跑 python get_cookies.py 產生，整段 JSON 字串貼進來
THREADS_STATE_JSON=

# === 選填：HTTP /ingest webhook（給 iOS Shortcut / curl 等外部呼叫用）===
# 自訂的 secret，呼叫端需要帶 X-Auth-Secret header 一致才能觸發
# 產生方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_SECRET=

# === 選填：/usage 指令查 Railway 用量 ===
# Railway dashboard → Account → Tokens 拿 Account Token
RAILWAY_API_TOKEN=

# === 選填：排程自動 /sync threads ===
# 設成 6 = 每 6 小時自動跑一次。0 或不設 = 關閉自動同步（只能手動 /sync threads）
AUTO_SYNC_HOURS=0
# 每次自動同步最多處理幾則新貼文（預設 20，避免一次跑太多吃 API 額度）
AUTO_SYNC_MAX=20
